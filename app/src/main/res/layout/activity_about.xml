<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".AboutActivity">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/about_toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Scrollable Main Content -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/about_toolbar"
        app:layout_constraintBottom_toTopOf="@id/footer_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Developer Info Section -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Profile Cardview -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardUseCompatPadding="true"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Profile Details -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <!-- Profile Picture -->
                    <ImageView
                        android:id="@+id/imgProfile"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:contentDescription="App Logo"
                        android:scaleType="centerCrop"
                        android:src="@drawable/profile"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:ignore="HardcodedText"/>

                    <!-- Divider -->
                    <View
                        android:id="@+id/dividerProfile"
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:background="#E0E0E0"
                        app:layout_constraintTop_toBottomOf="@id/imgProfile"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent" />

                    <!-- Name -->
                    <TextView
                        android:id="@+id/txtTitleName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="Name:"
                        android:textStyle="bold"
                        app:layout_constraintWidth_percent="0.35"
                        app:layout_constraintTop_toBottomOf="@id/dividerProfile"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/txtName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Muhammad Irsyaruddin Shah Bin Abdul Halim Shah"
                        app:layout_constraintTop_toTopOf="@id/txtTitleName"
                        app:layout_constraintStart_toEndOf="@id/txtTitleName"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:ignore="HardcodedText"/>

                    <!-- Student Number -->
                    <TextView
                        android:id="@+id/txtTitleStudentNo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Student No:"
                        android:textStyle="bold"
                        app:layout_constraintWidth_percent="0.35"
                        app:layout_constraintTop_toBottomOf="@id/txtName"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/txtStudentNo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="2024771509"
                        app:layout_constraintTop_toTopOf="@id/txtTitleStudentNo"
                        app:layout_constraintStart_toEndOf="@id/txtTitleStudentNo"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:ignore="HardcodedText"/>

                    <!-- Group -->
                    <TextView
                        android:id="@+id/txtTitleGroup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Group:"
                        android:textStyle="bold"
                        app:layout_constraintWidth_percent="0.35"
                        app:layout_constraintTop_toBottomOf="@id/txtStudentNo"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/txtGroup"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="RCDCS2405A"
                        app:layout_constraintTop_toTopOf="@id/txtTitleGroup"
                        app:layout_constraintStart_toEndOf="@id/txtTitleGroup"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:ignore="HardcodedText"/>

                    <!-- Programme -->
                    <TextView
                        android:id="@+id/txtTitleProgramme"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Programme:"
                        android:textStyle="bold"
                        app:layout_constraintWidth_percent="0.35"
                        app:layout_constraintTop_toBottomOf="@id/txtGroup"
                        app:layout_constraintStart_toStartOf="parent"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/txtProgramme"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="CS240 - Bachelor of Information Technology (Hons.)"
                        app:layout_constraintTop_toTopOf="@id/txtTitleProgramme"
                        app:layout_constraintStart_toEndOf="@id/txtTitleProgramme"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:ignore="HardcodedText"/>

                    <!-- Clickable URL -->
                    <TextView
                        android:id="@+id/txtURL"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:text="Click here to visit my website"
                        android:textColor="@color/accent_color"
                        android:textStyle="bold"
                        android:padding="8dp"
                        app:layout_constraintTop_toBottomOf="@id/txtProgramme"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:ignore="HardcodedText"/>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <!-- Footer Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/footer_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@color/background_color"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Copyright -->
        <TextView
            android:id="@+id/txtCopyright"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="© 2026 Developed by Irsya Shah."
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/txtVersion"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="HardcodedText"/>

        <!-- Version -->
        <TextView
            android:id="@+id/txtVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ver 1.0"
            android:textSize="12sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:ignore="HardcodedText"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>